@model RappiDozApp.Models.Restaurante

<div class="p-4">
    <form id="formRestaurante" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="text-center mb-5">
            <div class="position-relative d-inline-block">
                <div class="image-wrapper restaurant-image-wrapper">
                    <img id="previewRestaurante"
                         src="@(Model.LogoBinario != null ? $"data:{Model.ContentType};base64,{Convert.ToBase64String(Model.LogoBinario)}" : "/img/default-restaurante.png")"
                         class="rounded-circle shadow-sm restaurant-preview-img" />
                </div>
                <button type="button" class="btn btn-dark btn-sm rounded-circle position-absolute restaurant-camera-btn"
                        onclick="document.getElementById('fotoRestaurante').click()">
                    <i class="fas fa-camera"></i>
                </button>
                <input type="file" name="fotoArchivo" id="fotoRestaurante" class="d-none" accept="image/*" onchange="previewRestImg(this)" />
            </div>
            <h4 class="mt-3 fw-bold restaurant-identity-title">Identidad de la Sede</h4>
        </div>

        <div class="row g-4">
            <div class="col-12">
                <label class="form-label fw-bold">Nombre Comercial</label>
                <input asp-for="NombreComercial" class="form-control rd-input" placeholder="Ej: Rappi'Doz Central" required />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-bold">Dueño Asignado</label>
                <select asp-for="UsuarioId" asp-items="ViewBag.Usuarios" class="form-select rd-input">
                    <option value="">-- Seleccionar Dueño --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Categoría de Comida</label>
                <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" class="form-select rd-input">
                    <option value="">-- Seleccionar --</option>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-bold"><i class="far fa-clock me-1"></i> Hora de Apertura</label>
                <input asp-for="HoraApertura" type="time" class="form-control rd-input" required />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold"><i class="fas fa-history me-1"></i> Hora de Cierre</label>
                <input asp-for="HoraCierre" type="time" class="form-control rd-input" required />
            </div>

            <div class="col-12">
                <label class="form-label fw-bold">Ubicación Exacta</label>
                <textarea asp-for="Direccion" class="form-control rd-input" rows="2" placeholder="Provincia, Cantón y señas..."></textarea>
            </div>
        </div>

        <div class="mt-5 pt-4 border-top text-end">
            <button type="button" class="btn btn-light px-4 me-2 dashboard-cancel-btn-rounded" data-bs-dismiss="modal">
                Cancelar
            </button>
            <button type="button" onclick="guardarDatos('Restaurante')" class="btn px-5 py-2 dashboard-save-btn-rounded">
                <i class="fas fa-save me-2"></i> Guardar Sede
            </button>
        </div>
    </form>
</div>

<script src="~/js/Dashboard/form-restaurante.js"></script>