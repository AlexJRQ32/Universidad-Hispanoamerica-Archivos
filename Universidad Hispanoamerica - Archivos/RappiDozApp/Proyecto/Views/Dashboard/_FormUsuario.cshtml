@model RappiDozApp.Models.Usuario

<div class="p-4">
    <form id="formUsuario" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="text-center mb-4">
            <div class="position-relative d-inline-block">
                <div class="user-image-wrapper">
                    <img id="previewUser"
                         src="@(Model.FotoBinaria != null ? $"data:{Model.ContentType};base64,{Convert.ToBase64String(Model.FotoBinaria)}" : "/img/default-avatar.png")"
                         class="rounded-circle user-preview-img" />
                </div>
                <button type="button" class="btn rounded-circle position-absolute user-camera-btn"
                        onclick="document.getElementById('userFoto').click()">
                    <i class="fas fa-camera"></i>
                </button>
                <input type="file" name="fotoArchivo" id="userFoto" class="d-none" accept="image/*" onchange="previewUserImg(this)" />
            </div>
            <h4 class="mt-3 fw-bold user-form-title">@(Model.Id > 0 ? "Editar Usuario" : "Nuevo Usuario")</h4>
            <p class="user-form-subtitle">Completa la información del usuario</p>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label fw-bold user-form-label">Nombre Completo</label>
                <input asp-for="NombreCompleto" class="form-control rd-input" placeholder="Nombre y apellidos..." required />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold user-form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control rd-input" placeholder="correo@ejemplo.com" required />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold user-form-label">Rol de Usuario</label>
                <select asp-for="RolId" asp-items="ViewBag.Roles" class="form-select rd-input"></select>
            </div>
            <div class="col-12">
                <label class="form-label fw-bold user-form-label">
                    <i class="fas fa-lock me-1"></i> Contraseña @(Model.Id > 0 ? "(Dejar en blanco para no cambiar)" : "")
                </label>
                <input asp-for="PasswordHash" type="password" class="form-control rd-input" placeholder="••••••••" />
            </div>
        </div>

        <div class="mt-5 pt-4 border-top text-end">
            <button type="button" class="btn btn-light px-4 me-2 user-cancel-btn" data-bs-dismiss="modal">
                Cancelar
            </button>
            <button type="button" onclick="guardarDatos('Usuario')" class="btn px-5 py-2 user-save-btn">
                <i class="fas fa-user-check me-2"></i> Confirmar Usuario
            </button>
        </div>
    </form>
</div>

<script src="~/js/Dashboard/form-usuario.js"></script>