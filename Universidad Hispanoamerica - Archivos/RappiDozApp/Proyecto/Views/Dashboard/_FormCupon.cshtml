@model RappiDozApp.Models.Cupon

<div class="form-gold-wrapper fade-in">
    <form id="formCupon" autocomplete="off">
        <input type="hidden" asp-for="Id" />

        <div class="form-main-grid">

            @* COLUMNA IZQUIERDA: FORMULARIO *@
            <div class="form-col">
                <div class="input-group">
                    <label>Título del Cupón</label>
                    <input asp-for="Titulo" class="gold-input" placeholder="Ej. 25% RappiDoz">
                </div>

                <div class="input-group">
                    <label>Descripción Corta</label>
                    <input asp-for="Descripcion" class="gold-input" placeholder="Válido en...">
                </div>

                <div class="input-group">
                    <label>Categoría</label>
                    <select asp-for="CategoriaId" class="gold-input" asp-items="@(ViewBag.Categorias as List<SelectListItem>)">
                        <option value="">-- Todo el Menú --</option>
                    </select>
                </div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Código</label>
                        <input asp-for="Codigo" class="gold-input gold-uppercase-input">
                    </div>
                    <div class="input-group">
                        <label>Expiración</label>
                        <input type="date" name="FechaExpiracion" class="gold-input" value="@(Model.FechaExpiracion?.ToString("yyyy-MM-dd"))">
                    </div>
                </div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Valor</label>
                        <input asp-for="Descuento" id="vD" type="number" step="0.01" class="gold-input">
                    </div>
                    <div class="input-group">
                        <label>Tipo</label>
                        <select asp-for="EsPorcentaje" id="tD" class="gold-input">
                            <option value="true">Porcentaje (%)</option>
                            <option value="false">Monto Fijo (₡)</option>
                        </select>
                    </div>
                </div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Stock</label>
                        <input asp-for="Stock" type="number" class="gold-input">
                    </div>
                    <div class="input-group checkbox-group">
                        <input type="checkbox" asp-for="Activo" class="gold-checkbox">
                        <label class="checkbox-label">Activo</label>
                    </div>
                </div>
            </div>

            @* COLUMNA DERECHA: CÍRCULO CON CUPÓN *@
            <div class="preview-aside">
                <span class="preview-label">PREVISUALIZACIÓN</span>
                <div class="preview-circle">
                    <div class="minimal-coupon">
                        <h1 id="bD">@Model.Descuento@(Model.EsPorcentaje ? "%" : "₡")</h1>
                    </div>
                </div>
            </div>

        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-link dashboard-modal-close" data-bs-dismiss="modal">Cerrar</button>
            <button type="button" onclick="guardarDatos('Cupon')" class="dashboard-primary-btn">
                Aplicar Cambios
            </button>
        </div>
    </form>
</div>

<script src="~/js/Dashboard/form-cupon.js"></script>