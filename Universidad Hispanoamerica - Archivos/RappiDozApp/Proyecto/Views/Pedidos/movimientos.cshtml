@using System.Linq
@model IEnumerable<RappiDozApp.Models.Pedido>

@{
    ViewData["Title"] = "Mis Comprobantes | Rappi'Doz";
}

<div class="movimientos-container">
    <div class="movimientos-card">

        <div class="header-seccion">
            <i class="fa-solid fa-receipt header-seccion-icon"></i>
            <h1 class="header-seccion-title">Mis Comprobantes</h1>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="movimientos-empty">
                <i class="fa-solid fa-box-open movimientos-empty-icon"></i>
                <p class="movimientos-empty-text">Aún no tienes pedidos registrados.</p>
                <a asp-controller="Home" asp-action="Index" class="movimientos-empty-link">Explorar Restaurantes</a>
            </div>
        }
        else
        {
            @foreach (var pedido in Model)
            {
                <details class="movimiento-detail">
                    <summary class="movimiento-summary">
                        <div>
                            <p class="movimiento-order-title">Orden #@pedido.Id</p>
                            <p class="movimiento-date">
                                <i class="fa-regular fa-calendar-days"></i> @pedido.FechaHora.ToString("D")
                                <i class="fa-regular fa-clock movimiento-time-icon"></i> @pedido.FechaHora.ToString("t")
                            </p>
                        </div>
                        <div class="movimiento-status-wrap">
                            @{
                                var claseEstado = pedido.Estado == "Entregado"
                                    ? "status-entregado"
                                    : pedido.Estado == "Cancelado"
                                        ? "status-cancelado"
                                        : "status-proceso";
                            }
                            <span class="movimiento-status-badge @claseEstado">
                                @pedido.Estado
                            </span>
                            <div class="movimiento-total-preview">₡@pedido.Total.ToString("N0")</div>
                        </div>
                    </summary>

                    <div class="movimiento-factura-box">
                        <div class="movimiento-factura-header">
                            <h2 class="movimiento-factura-title">DETALLE DE FACTURACIÓN</h2>
                            <div class="movimiento-factura-divider"></div>
                        </div>

                        <table class="movimiento-table">
                            <thead>
                                <tr class="movimiento-table-head-row">
                                    <th class="movimiento-table-th-left">Cant.</th>
                                    <th class="movimiento-table-th-left">Descripción</th>
                                    <th class="movimiento-table-th-right">Unitario</th>
                                    <th class="movimiento-table-th-right">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (pedido.Detalles != null)
                                {
                                    foreach (var detalle in pedido.Detalles)
                                    {
                                        <tr class="movimiento-table-row">
                                            <td class="movimiento-cell-qty">@detalle.Cantidad</td>
                                            <td class="movimiento-cell-name">@(detalle.Producto?.Nombre ?? "Producto")</td>
                                            <td class="movimiento-cell-price">₡@detalle.PrecioHistorico.ToString("N0")</td>
                                            <td class="movimiento-cell-total">₡@((detalle.PrecioHistorico * detalle.Cantidad).ToString("N0"))</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                        <div class="movimiento-breakdown">
                            @{
                                decimal cargosFijos = 2000;
                                decimal subtotalProductos = pedido.Detalles?.Sum(d => d.PrecioHistorico * d.Cantidad) ?? 0;
                                decimal baseImponible = (subtotalProductos + cargosFijos - pedido.MontoDescuento) / 1.13m;
                                decimal iva = (subtotalProductos + cargosFijos - pedido.MontoDescuento) - baseImponible;
                            }

                            <div class="movimiento-line">
                                <span>Subtotal Productos:</span>
                                <span>₡@subtotalProductos.ToString("N0")</span>
                            </div>
                            <div class="movimiento-line">
                                <span>Cargos de Entrega y Servicio:</span>
                                <span>₡@cargosFijos.ToString("N0")</span>
                            </div>

                            @if (pedido.MontoDescuento > 0)
                            {
                                <div class="movimiento-discount-line">
                                    <span><i class="fa-solid fa-tag"></i> Descuento Cupón:</span>
                                    <span>-₡@pedido.MontoDescuento.ToString("N0")</span>
                                </div>
                            }

                            <div class="movimiento-tax-line">
                                <span>Impuesto de Ventas (13% IVA):</span>
                                <span>₡@iva.ToString("N0")</span>
                            </div>

                            <div class="movimiento-total-line">
                                <span>MONTO TOTAL:</span>
                                <span>₡@pedido.Total.ToString("N0")</span>
                            </div>
                        </div>

                        <div class="movimiento-footer">
                            <p class="movimiento-footer-thanks">¡Gracias por preferir Rappi'Doz!</p>
                            <p class="movimiento-auth-code">
                                AUTH-CODE: @pedido.Id-@pedido.FechaHora.Ticks.ToString().Substring(13)
                            </p>
                            <div class="movimiento-barcode-wrap">
                                <i class="fa-solid fa-barcode movimiento-barcode-icon"></i>
                            </div>
                        </div>
                    </div>
                </details>
            }
        }
    </div>
</div>
