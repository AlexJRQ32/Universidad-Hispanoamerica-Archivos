@model IEnumerable<RappiDozApp.Models.Producto>

@{
    ViewData["Title"] = "Menú de " + (ViewBag.RestauranteNombre ?? "Restaurante");
}

@* ELEMENTO PARA LA ANIMACIÓN (Bolsita voladora) *@
<div id="bolsa-fancy-vuelo" class="bolsa-fancy-vuelo">
    <i class="fa-solid fa-bag-shopping"></i>
</div>

<main class="restaurante-main">
    <div class="contenedor-menu-estrecho">

        <div class="restaurante-header">
            <h1 class="restaurante-title">@ViewBag.RestauranteNombre</h1>
            <p class="restaurante-subtitle">Toque para añadir</p>
        </div>

        @foreach (var producto in Model)
        {
            <div class="card-platillo-moderno">
                <div class="visual-section">
                    <img src="@producto.ImagenBase64" class="foto-circular">
                </div>

                <div class="info-section">
                    <h3>@producto.Nombre</h3>
                    <p class="producto-descripcion">@producto.Descripcion</p>
                    <div class="precio-badge">₡@producto.Precio.ToString("N0")</div>
                </div>

                <div class="action-section">
                    @* Formulario manejado por AJAX *@
                    <form class="form-agregar-carrito" asp-controller="Carritos" asp-action="Agregar" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productoId" value="@producto.Id" />
                        <input type="hidden" name="nombre" value="@producto.Nombre" />
                        <input type="hidden" name="precio" value="@producto.Precio" />
                        <input type="hidden" name="imagen" value="@producto.ImagenBase64" />
                        <input type="hidden" name="cantidad" value="1" />

                        <button type="button" class="btn-añadir-premium" onclick="agregarConAnimacion(this)">
                            <i class="fa-solid fa-plus"></i>
                            <span>Añadir</span>
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</main>

<script src="~/js/Restaurantes/restaurante.js"></script>