@using Microsoft.AspNetCore.Http
@using System.Globalization
@inject IHttpContextAccessor HttpContextAccessor
@inject RappiDozApp.Data.ApplicationDbContext _context
@model IEnumerable<RappiDozApp.Models.Restaurante>

@{
    ViewData["Title"] = "Inicio | RappiDoz";
    var userId = HttpContextAccessor.HttpContext.Session.GetInt32("UsuarioId");

    // VALORES POR DEFECTO (San José)
    bool tieneUbicacion = false;
    double latActual = 9.9331; 
    double lngActual = -84.1112;

    if (userId.HasValue)
    {
        try 
        {
            // Buscamos la última ubicación guardada
            var ultimaUbi = _context.UbicacionUsuario
                .Where(u => u.IdUsuario == userId.Value)
                .OrderByDescending(u => u.IdUbicacion) // Asegúrate que el nombre sea Id o IdUbicacion según tu clase
                .FirstOrDefault();

            if (ultimaUbi != null)
            {
                tieneUbicacion = true;
                // USAMOS CONVERT PARA EVITAR EL ERROR DE CAST (Double vs Single)
                latActual = Convert.ToDouble(ultimaUbi.Latitud);
                lngActual = Convert.ToDouble(ultimaUbi.Longitud);
            }
        }
        catch (Exception) 
        {
            // Si hay error de casteo o base de datos, mantenemos los valores por defecto
            tieneUbicacion = false;
        }
    }
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

@* HERO SECCIÓN *@
<section class="hero">
    <div class="hero-content">
        <h1 class="hero-title">Entrega de comida hasta tu puerta</h1>
        <form asp-controller="Home" asp-action="Explorar" method="get" class="search-container">
            <div class="input-wrapper">
                <i class="fas fa-map-marker-alt"></i>
                <input type="text" name="buscar" placeholder="Ingresar dirección de entrega" required>
            </div>
            <button type="submit" class="btn-buscar">Buscar comida</button>
        </form>
    </div>
</section>

<main class="contenido-principal">
    <div class="zona-restringida">

        @* CATEGORÍAS *@
        <section class="categorias categorias-section">
            <h2 class="section-title-centered">Explorar por categoría</h2>
            <div class="grid-categorias">
                @foreach (var cat in new[] { (I: "hamburger", N: "Burgers"), (I: "pizza-slice", N: "Pizza"), (I: "drumstick-bite", N: "Pollo"), (I: "ice-cream", N: "Postres"), (I: "utensils", N: "Más") })
                {
                    <a asp-controller="Home" asp-action="Explorar" asp-route-buscar="@cat.N" class="categoria-card categoria-link">
                        <i class="fas fa-@cat.I category-icon"></i>
                        <p class="category-label">@cat.N</p>
                    </a>
                }
            </div>
        </section>

        @* RESTAURANTES *@
        <section class="restaurantes restaurantes-section">
            <div class="container-header">
                <h2>Restaurantes populares</h2>
                <a asp-action="Explorar" asp-controller="Home" class="section-link">Ver todos</a>
            </div>

            <div class="scroll-horizontal-wrapper">
                <div class="grid-restaurantes-dinamico">
                    @if (Model != null)
                    {
                        @foreach (var restaurante in Model)
                        {
                            <a asp-controller="Restaurantes" asp-action="Menu" asp-route-id="@restaurante.Id" class="link-restaurante-horizontal">
                                <div class="restaurant-card @(restaurante.EstaAbierto ? "" : "cerrado-filtro")">
                                    <div class="card-img-wrapper">
                                        <img src="data:@(restaurante.ContentType ?? "image/png");base64,@Convert.ToBase64String(restaurante.LogoBinario ?? new byte[0])" class="restaurant-logo">
                                        @if (!restaurante.EstaAbierto)
                                        {
                                            <div class="card-closed-overlay">
                                                <span class="badge-cerrado">CERRADO</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="info">
                                        <h3>@restaurante.NombreComercial</h3>
                                        <p class="restaurant-schedule"><i class="fa-regular fa-clock"></i> @restaurante.HoraApertura.ToString(@"hh\:mm") - @restaurante.HoraCierre.ToString(@"hh\:mm")</p>
                                        <p class="meta">⭐ 4.8 • 20 min</p>
                                    </div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </section>

        @* SECCIÓN MAPA ACTUALIZADA *@
        <section id="seccion-mapa" class="seccion-mapa">
            <div class="map-card">
                <h2 class="map-title">¿A dónde enviamos hoy?</h2>

                <div id="map" data-lat="@latActual.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-lng="@lngActual.ToString(System.Globalization.CultureInfo.InvariantCulture)"></div>

                @if (userId == null)
                {
                    <div class="locked-overlay">
                        <i class="fas fa-lock lock-icon"></i>
                        <h3 class="locked-title">Inicia sesión para guardar ubicaciones</h3>
                        <a asp-controller="Accesos" asp-action="Login" class="locked-login-link">INICIAR SESIÓN</a>
                    </div>
                }
                else
                {
                    <form id="formUbicacion" asp-controller="Ubicaciones" asp-action="GuardarUbicacion" method="post" class="ubicacion-form">
                        @Html.AntiForgeryToken()

                        <div class="field-block">
                            <label class="field-label">Etiqueta tu dirección:</label>
                            <input type="text" name="nombreUbicacion" class="input-nombre-ubi" placeholder="Ej: Casa, Trabajo, Gimnasio..." required>
                        </div>

                        <input type="hidden" id="Latitud" name="Latitud" value="@latActual.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                        <input type="hidden" id="Longitud" name="Longitud" value="@lngActual.ToString(System.Globalization.CultureInfo.InvariantCulture)" />

                        <button type="submit" id="btn-confirmar-mapa" class="btn-confirmar-mapa">
                            <i class="fas fa-map-pin me-2"></i> GUARDAR ESTA DIRECCIÓN
                        </button>
                    </form>
                }
            </div>
        </section>

        @* PASOS *@
        <section class="como-funciona">
            <div class="pasos">
                <div class="paso">
                    <i class="fas fa-map-marker-alt"></i>
                    <h3>Ingresa dirección</h3>
                    <p>Dinos dónde estás para mostrarte los restaurantes con cobertura en tu zona.</p>
                </div>
        
                <div class="paso">
                    <i class="fas fa-utensils"></i>
                    <h3>Elige tu comida</h3>
                    <p>Navega por los menús de tus comercios favoritos y arma tu pedido ideal.</p>
                </div>
        
                <div class="paso">
                    <i class="fas fa-motorcycle"></i>
                    <h3>Recibe rápido</h3>
                    <p>¡Y listo! Nuestros repartidores vuelan para entregarte tu antojo calientito.</p>
                </div>
            </div>
        </section>
    </div>
</main>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/Home/index.js"></script>
}