@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña - Rappi'Doz</title>
    <link rel="stylesheet" href="~/css/Accesos/login.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

   
    <div class="form">
        <h1>Recuperar Contraseña</h1>
        
        <p class="form-description">
            Ingresa tu correo electrónico para enviarte las instrucciones de restablecimiento.
        </p>

        <form asp-controller="Accesos" asp-action="OlvidastePassword" method="post">
            @Html.AntiForgeryToken()

            <section>
                <div class="container-translucid">
                    <input type="email" name="correo" placeholder="Correo electrónico" autofocus required>
                    <i class="fa-solid fa-envelope"></i>
                </div>
            </section>

            @if (ViewBag.Mensaje != null)
            {
                <p class="feedback-success">@ViewBag.Mensaje</p>
            }
            @if (ViewBag.Error != null)
            {
                <p class="feedback-error">@ViewBag.Error</p>
            }

            <section>
                <div class="container-translucid">
                    <button type="submit" id="button">
                        Enviar enlace
                    </button>
                </div>
            </section>

            <div class="register">
                <a asp-action="Login" id="register">Volver al Inicio de sesión</a>
            </div>
        </form>
    </div>
</body>
</html>
