@{
    ViewData["Title"] = "Selección de Perfil";
    // Capturamos el ID del usuario que viene del controlador
    int userId = ViewBag.UsuarioId ?? 0;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Selección de Perfil - Rappi'Doz</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/Accesos/selector.css">
</head>
<body>


    <div class="form">
        <div class="selector-brand-mini">
            <span class="selector-brand-rappi">Rappi</span><span class="selector-brand-doz">'Doz</span>
        </div>

        <h1>¿Quién eres?</h1>

        <div class="cards-wrapper">
            @* FORMULARIO PARA USUARIO COMÚN (ROL 1) *@
        <form asp-controller="Accesos" asp-action="AsignarRol" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="usuarioId" value="@userId" />
                <input type="hidden" name="rolId" value="1" />
                <button type="submit" class="card-option">
                    <i class="fa-solid fa-pizza-slice"></i>
                    <h2>Usuario</h2>
                    <p>Quiero pedir comida</p>
                </button>
            </form>

            @* FORMULARIO PARA RESTAURANTE (ROL 2) *@
            <form asp-controller="Accesos" asp-action="AsignarRol" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="usuarioId" value="@userId" />
                <input type="hidden" name="rolId" value="2" />
                <button type="submit" class="card-option">
                    <i class="fa-solid fa-shop"></i>
                    <h2>Restaurante</h2>
                    <p>Quiero vender</p>
                </button>
            </form>
        </div>

        <div class="register">
            <a asp-controller="Accesos" asp-action="Login">
                <i class="fa-solid fa-arrow-left"></i> Volver al inicio
            </a>
        </div>
    </div>
</body>
</html>
