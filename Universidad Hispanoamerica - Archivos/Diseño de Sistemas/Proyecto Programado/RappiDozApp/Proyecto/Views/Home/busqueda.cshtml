@model IEnumerable<RappiDozApp.Models.Restaurante>

@{
    ViewData["Title"] = "Explora Sabores | Rappi'Doz";
    var textoBuscado = Context.Request.Query["buscar"];
}

<!-- Styles moved to ~/css/_StylesNavbar.css -->



<main class="main-search">
    @* --- BUSCADOR --- *@
    <section class="hero-section">
        <div class="hero-inner">
            <h1 class="search-title">Tu próximo antojo</h1>
            <p class="search-subtitle">Busca por nombre, comida, zona o categoría.</p>

            <form asp-action="Explorar" method="get" class="search-form">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" name="buscar" value="@textoBuscado" placeholder="¿Qué quieres comer?">
                <button type="submit">Buscar</button>
            </form>
        </div>
    </section>

    @* --- RESULTADOS --- *@
    <section class="results-section">

        <div class="results-header">
            <h2 class="results-title">
                @(string.IsNullOrEmpty(textoBuscado) ? "Restaurantes" : "Resultados: " + textoBuscado)
            </h2>
            <small class="results-count">@Model.Count() locales</small>
        </div>

        <div class="results-list">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="res-card-ref @(item.EstaAbierto ? string.Empty : "is-closed")">

                        <div class="res-img-container">
                            @if (item.LogoBinario != null)
                            {
                                <img src="data:@item.ContentType;base64,@Convert.ToBase64String(item.LogoBinario)" class="res-image">
                            }
                            else
                            {
                                <img class="res-image">
                            }

                            @if (!item.EstaAbierto)
                            {
                                <div class="result-overlay">
                                    <span class="result-closed-badge">CERRADO</span>
                                </div>
                            }
                        </div>

                        <div class="res-info-body">
                            <div class="result-top-row">
                                <div>
                                    <h3 class="res-title">@item.NombreComercial</h3>
                                    <p class="location-info">
                                        <i class="fa-solid fa-location-dot location-icon"></i>
                                        <span class="location-text">@item.Direccion</span>
                                    </p>
                                </div>
                                <span class="badge-status @(item.EstaAbierto ? "open" : "closed")">
                                    @(item.EstaAbierto ? "ABIERTO" : "CERRADO")
                                </span>
                            </div>

                            <div class="result-footer">
                                <div class="delivery-meta">
                                    <span class="hide-mobile"><i class="fa-regular fa-clock"></i> @item.HoraApertura.ToString(@"hh\:mm")-@item.HoraCierre.ToString(@"hh\:mm")<br></span>
                                    <span class="delivery-price">₡1,000 envío • 30 min</span>
                                </div>

                                <a asp-controller="Restaurantes" asp-action="Menu" asp-route-id="@item.Id" class="btn-menu-slim @(item.EstaAbierto ? "" : "disabled")">
                                    @(item.EstaAbierto ? "Ver Menú" : "Local")
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-results">
                    <p>No hay coincidencias.</p>
                </div>
            }
        </div>
    </section>
</main>