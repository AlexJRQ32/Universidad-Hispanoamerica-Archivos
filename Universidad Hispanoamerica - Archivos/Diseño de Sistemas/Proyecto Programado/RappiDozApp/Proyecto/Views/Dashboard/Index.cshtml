@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Panel de Control | RappiDoz";
    var rolUsuario = HttpContextAccessor.HttpContext.Session.GetString("RolUsuario");
    var nombreUsuario = HttpContextAccessor.HttpContext.Session.GetString("NombreUsuario") ?? "Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">

    <link href="~/css/Dashboard/index.css" rel="stylesheet" />
    <link href="~/css/Dashboard/cupones-list.css" rel="stylesheet" />
    <link href="~/css/Dashboard/form-cupon.css" rel="stylesheet" />
    <link href="~/css/Dashboard/form-producto.css" rel="stylesheet" />
    <link href="~/css/Dashboard/form-restaurante.css" rel="stylesheet" />
    <link href="~/css/Dashboard/form-usuario.css" rel="stylesheet" />
    <link href="~/css/Dashboard/menus-list.css" rel="stylesheet" />
    <link href="~/css/Dashboard/restaurantes-list.css" rel="stylesheet" />
    <link href="~/css/Dashboard/usuario-list.css" rel="stylesheet" />
</head>
<body>

    <button class="btn-toggle" id="menuToggle">
        <i class="fa-solid fa-bars"></i>
    </button>

    <div class="sidebar-overlay" id="overlay"></div>

    <div class="dashboard-wrapper">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header mb-5">
                <h4 class="fw-800 dashboard-brand-title">Rappi'Doz <span class="dashboard-brand-accent">Gold</span></h4>
            </div>

            <nav class="sidebar-nav">
                <button type="button" onclick="location.reload()" class="nav-item active">
                    <i class="fa-solid fa-house me-2"></i> <span>Resumen</span>
                </button>
                <button type="button" onclick="cargarSeccion('Menus')" class="nav-item">
                    <i class="fa-solid fa-utensils me-2"></i> <span>Mi Menú</span>
                </button>
                <button type="button" onclick="cargarSeccion('Restaurantes')" class="nav-item">
                    <i class="fa-solid fa-store me-2"></i> <span>Restaurantes</span>
                </button>

                @if (rolUsuario == "Administrador")
                {
                    <button type="button" onclick="cargarSeccion('Usuarios')" class="nav-item">
                        <i class="fa-solid fa-user-shield me-2"></i> <span>Usuarios</span>
                    </button>
                    <button type="button" onclick="cargarSeccion('Cupones')" class="nav-item">
                        <i class="fa-solid fa-ticket me-2"></i> <span>Cupones</span>
                    </button>
                }
            </nav>

            <div class="mt-auto p-3 rounded-4 dashboard-session-card">
                <p class="small mb-1 text-muted">Sesión de:</p>
                <p class="fw-bold mb-3 text-white">@nombreUsuario</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-danger w-100 border-0">
                    <i class="fa-solid fa-power-off me-2"></i> Salir
                </a>
            </div>
        </aside>

        <main class="main-content" id="contenedor-dinamico">
            <div class="animate__animated animate__fadeInUp">
                <h1 class="fw-800 mb-1 dashboard-welcome">Bienvenido, @nombreUsuario</h1>
                <p class="text-muted mb-5">Panel de administración en tiempo real.</p>

                <div class="row g-4 mb-5">
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="stat-card">
                            <div class="icon-circle icon-circle-gold">
                                <i class="fa-solid fa-shop"></i>
                            </div>
                            <div>
                                <span class="label">Sedes</span>
                                <span class="value">@ViewBag.TotalRestaurantes</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="stat-card">
                            <div class="icon-circle icon-circle-brown">
                                <i class="fa-solid fa-utensils"></i>
                            </div>
                            <div>
                                <span class="label">Platillos</span>
                                <span class="value">@ViewBag.TotalProductos</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-4 p-md-5 rounded-5 quick-actions-card animate__animated animate__zoomIn">
                    <h3 class="fw-bold mb-3">Accesos Rápidos</h3>
                    <div class="d-flex flex-wrap gap-2">
                        <button onclick="cargarSeccion('Menus')" class="btn btn-dark px-4 py-3 rounded-4">
                            Ver Catálogo
                        </button>
                        <button onclick="cargarSeccion('Restaurantes')" class="btn btn-outline-dark px-4 py-3 rounded-4">
                            Gestionar Sedes
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div class="modal fade" id="rdModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content shadow-lg dashboard-modal-content">
                <div id="modalContainerBody"></div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/Dashboard/index.js"></script>
</body>
</html>
